# Environment (dev or prod)
ENVIRONMENT=dev

# OpenAI
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ALLOWED_TELEGRAM_USER_IDS=your_telegram_user_id_here

# iCloud Calendar (CalDAV)
ICLOUD_EMAIL=your_icloud_email@icloud.com
ICLOUD_APP_PASSWORD=your_icloud_app_password_here

# Optional: Google Calendar (not currently used)
GOOGLE_CALENDAR_EMAIL=
GOOGLE_APP_PASSWORD=

# Database (optional - defaults to data/{ENVIRONMENT}/app.db)
# DATABASE_URL=

# Logging
LOG_LEVEL=INFO

# Work Agent — Gmail Push Notifications via Google Cloud Pub/Sub
# One-time GCP setup required (see docs). Leave blank to use fallback polling instead.
GOOGLE_PUBSUB_PROJECT_ID=your-gcp-project-id
GOOGLE_PUBSUB_TOPIC_NAME=gmail-push
GMAIL_PUBSUB_VERIFICATION_TOKEN=your-random-secret-token
# Fallback: poll for new emails every N minutes when Pub/Sub is not configured
WORK_EMAIL_POLL_FALLBACK_MINUTES=15
