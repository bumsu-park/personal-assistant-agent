# Environment (dev or prod)
ENVIRONMENT=dev

# LLM Provider — one of: anthropic, openai, deepseek, qwen
LLM_PROVIDER=anthropic

# Anthropic (Claude) — used when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI — used when LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# DeepSeek — used when LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your_deepseek_key_here
DEEPSEEK_MODEL=deepseek-chat

# Qwen — used when LLM_PROVIDER=qwen
QWEN_API_KEY=your_qwen_key_here
QWEN_MODEL=qwen-max

# FastAPI
API_KEY=your_api_key_here

# iCloud Calendar (CalDAV)
ICLOUD_EMAIL=your_icloud_email@icloud.com
ICLOUD_APP_PASSWORD=your_icloud_app_password_here

# Gmail
GMAIL_CREDENTIALS_PATH=credentials/gmail_credentials.json

# Logging
LOG_LEVEL=INFO
